class Solution {
    void pushZerosToEnd(int[] arr) {
        // code here
       
        int insertPos = 0;

        // Step 1: Shift all non-zero elements to the front
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] != 0) {
                arr[insertPos] = arr[i];
                insertPos++;
            }
        }

        // Step 2: Fill the remaining trailing spaces with zeros
        while (insertPos < arr.length) {
            arr[insertPos] = 0;
            insertPos++;
        }
    }
}
